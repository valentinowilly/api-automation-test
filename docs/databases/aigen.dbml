Enum "config_autopo_config_type_enum" {
  "pr_validation"
  "setting_parameter"
}

Enum "failed_emails_status_enum" {
  "pending_retry"
  "failed"
  "success"
}

Table "categories" {
  "id" "int unsigned" [pk, not null, increment]
  "name" varchar(10) [not null]
  "created_at" timestamp [default: `CURRENT_TIMESTAMP`]
  "updated_at" "timestamp on update CURRENT_TIMESTAMP" [default: `CURRENT_TIMESTAMP`]
  "parent_id" "int unsigned"
  "parent_name" varchar(10)
  "level" int [not null, default: 0]
  "is_active" tinyint(1) [default: 1]
}

Table "category_matrices" {
  "id" "int unsigned" [pk, not null, increment]
  "category_id" "int unsigned" [not null]
  "main_category_user_id" "int unsigned" [not null]
  "sub_category_user_id" "int unsigned" [not null]
  "leader_category_user_id" "int unsigned" [not null]
  "management_user_id" "int unsigned" [not null]
  "is_active" tinyint(1) [not null, default: 1]
  "created_at" datetime [default: `CURRENT_TIMESTAMP`]
  "updated_at" "datetime on update CURRENT_TIMESTAMP" [default: `CURRENT_TIMESTAMP`]
  "deleted_at" datetime
}

Table "config_autopo" {
  "id" int [pk, not null, increment]
  "config_type" config_autopo_config_type_enum [not null]
  "server_group" varchar(5)
  "config_condition" varchar(255)
  "config_operator" varchar(255)
  "config_value" varchar(255)
  "active_when" datetime
  "is_active" tinyint(1) [not null, default: 1]
  "createdAt" datetime [not null]
  "updatedAt" datetime [not null]
}

Table "config_milestone" {
  "id" int [pk, not null, increment]
  "status_milestone" varchar(50)
  "status_submilestone" varchar(100)
  "actor" varchar(50)
}

Table "config_reason" {
  "id" int [pk, not null, increment]
  "reason" varchar(255) [not null]
  "role_id" "int unsigned"
  "is_active" tinyint(1) [not null, default: 1]
  "created_at" timestamp [default: `CURRENT_TIMESTAMP`]
  "updated_at" "timestamp on update CURRENT_TIMESTAMP" [default: `CURRENT_TIMESTAMP`]
}

Table "config_values" {
  "id" "int unsigned" [pk, not null, increment]
  "config_condition" varchar(255)
  "available_values" json
  "created_at" datetime [default: `CURRENT_TIMESTAMP`]
  "updated_at" "datetime on update CURRENT_TIMESTAMP" [default: `CURRENT_TIMESTAMP`]
  "deleted_at" datetime
  "server_group" varchar(5)
}

Table "documents" {
  "id" int [pk, not null, increment]
  "file_path" varchar(255) [not null]
  "rfq_number" varchar(20) [not null]
  "createdAt" datetime [not null]
  "updatedAt" datetime [not null]
  "is_latest" tinyint(1) [not null, default: 0]
  "batch" int
  "vendor_code" varchar(20)
}

Table "emails" {
  "id" int [pk, not null, increment]
  "from" varchar(255) [not null]
  "to" text [not null]
  "subject" varchar(255) [not null]
  "body" text [not null]
  "html" text
  "status" tinyint(1) [not null, note: 'true: sent, false: failed']
  "createdAt" datetime [not null]
  "updatedAt" datetime [not null]
}

Table "evidences" {
  "id" int [pk, not null, increment]
  "file_path" varchar(255) [not null]
  "is_latest" tinyint(1) [not null, default: 0]
  "batch" int
  "rfq_item_id" int [not null]
  "createdAt" datetime [not null]
  "updatedAt" datetime [not null]

  Indexes {
    rfq_item_id [type: btree, name: "rfq_item_id"]
  }
}

Table "failed_emails" {
  "id" int [pk, not null, increment]
  "email_type" varchar(255) [not null, note: 'The type of email that failed, e.g., "RequestForQuotation"']
  "rfq_number" varchar(255) [not null]
  "to_recipients" json [not null, note: 'JSON array of "to" email addresses']
  "cc_recipients" json [note: 'JSON array of "cc" email addresses']
  "params" json [not null, note: 'Parameters for the email template']
  "status" failed_emails_status_enum [not null, default: 'pending_retry']
  "retry_count" int [not null, default: 0]
  "last_error" text [note: 'The last error message received during sending']
  "createdAt" datetime [not null]
  "updatedAt" datetime [not null]
}

Table "images" {
  "id" int [pk, not null, increment]
  "file_path" varchar(255) [not null]
  "rfq_item_id" int [not null]
  "createdAt" datetime [not null]
  "updatedAt" datetime [not null]
  "is_latest" tinyint(1) [not null, default: 0]
  "batch" int
  "type" varchar(255) [default: 'GENERAL', note: 'Image type/category (e.g., GENERAL, DIC_REJECT_REASON, etc.)']

  Indexes {
    rfq_item_id [type: btree, name: "rfq_item_id"]
  }
}

Table "log_acl" {
  "id" "int unsigned" [pk, not null, increment]
  "user_id" "int unsigned" [not null]
  "module" varchar(255) [not null]
  "action" varchar(255) [not null]
  "value_before" json
  "value_after" json
  "actor" varchar(255) [not null]
  "created_at" datetime
  "updated_at" datetime
  "user_email" varchar(255) [not null]
}

Table "log_activity" {
  "id" int [pk, not null, increment]
  "user_id" int [not null]
  "user_name" varchar(100) [not null]
  "action_type" varchar(100) [not null]
  "action_description" text
  "created_at" datetime [not null]
  "updated_at" datetime [not null]
}

Table "log_master_data" {
  "id" "int unsigned" [pk, not null, increment]
  "user_id" "int unsigned" [not null]
  "module" varchar(255) [not null]
  "action" varchar(255) [not null]
  "value_before" json
  "value_after" json
  "actor" varchar(255) [not null]
  "created_at" timestamp [default: `CURRENT_TIMESTAMP`]
  "updated_at" "timestamp on update CURRENT_TIMESTAMP" [default: `CURRENT_TIMESTAMP`]
  "user_email" varchar(255) [not null]
}

Table "log_quotation" {
  "id" int [pk, not null, increment]
  "rfq_number" varchar(15) [not null]
  "item_code" varchar(10) [not null]
  "item_id" int
