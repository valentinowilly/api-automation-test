  Note: 'Mapping Matrix dan Master Data'
}

Ref "fk_categories_parent_id":"categories"."id" < "categories"."parent_id"

Ref "fk_category_matrices_category_id":"categories"."id" < "category_matrices"."category_id" [update: cascade, delete: cascade]

Ref "fk_category_matrices_leader_category_user_id":"users"."id" < "category_matrices"."leader_category_user_id" [update: cascade, delete: cascade]

Ref "fk_category_matrices_main_category_user_id":"users"."id" < "category_matrices"."main_category_user_id" [update: cascade, delete: cascade]

Ref "fk_category_matrices_management_user_id":"users"."id" < "category_matrices"."management_user_id" [update: cascade, delete: cascade]

Ref "fk_category_matrices_sub_category_user_id":"users"."id" < "category_matrices"."sub_category_user_id" [update: cascade, delete: cascade]

Ref "fk_config_reason_role_id":"roles"."id" < "config_reason"."role_id"

Ref "evidences_ibfk_1":"rfq_library"."id" < "evidences"."rfq_item_id" [update: cascade, delete: cascade]

Ref "images_ibfk_1":"rfq_library"."id" < "images"."rfq_item_id" [update: cascade, delete: cascade]

