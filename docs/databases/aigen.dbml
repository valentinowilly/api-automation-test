  "deliv_date_pr" datetime
  "deliv_date_bid" datetime
  "item_price_pr" int
  "item_price_bid" int
  "total_price_pr" int
  "total_price_bid" int
  "deskripsi" text
  "status" varchar(50)
  "reject_reason_on_vendor" text
  "reject_reason_on_user" text
  "image_link" longtext
  "created_at" datetime [not null]
  "updated_at" datetime [not null]
}

Table "log_sla" {
  "id" int [pk, not null, increment]
  "rfq_number" varchar(15) [not null]
  "pr_number" varchar(15) [not null]
  "item_code" varchar(10) [not null]
  "item_id" int
  "category" varchar(10)
  "cl_id" int
  "cl_name" varchar(100)
  "cs_id" int
  "cs_name" varchar(100)
  "vendor_code" varchar(15)
  "vendor_name" varchar(150) [not null]
  "vendor_type" varchar(10) [not null]
  "actor" varchar(15) [not null]
  "milestone" varchar(50) [not null]
  "submilestone" varchar(50) [not null]
  "start_date" datetime [not null]
  "end_date" datetime
  "lead_time" int
  "lead_time_regular" int [default: 0]
}

Table "master_divisions" {
  "id" "int unsigned" [pk, not null, increment]
