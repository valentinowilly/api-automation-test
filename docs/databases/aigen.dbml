  "id" "int unsigned" [pk, not null, increment]
  "slug" varchar(255) [not null]
  "name" varchar(255) [not null]
  "is_active" tinyint(1) [not null, default: 1]
  "created_at" timestamp
  "updated_at" timestamp
}

Table "pr_library" {
  "id" int [pk, not null, increment]
  "uuid" varchar(64) [not null]
  "rfq_number" varchar(15) [not null]
  "pr_number" varchar(15) [not null]
  "item_code" varchar(10)
  "item_text" text
  "quantity" int
  "uom" varchar(10)
  "item_value" decimal(10,2)
  "src_value" decimal(10,2)
  "src_currency" varchar(5)
  "convert_value" decimal(10,2)
  "convert_currency" varchar(5)
  "pr_release_date" datetime
  "server_groups" varchar(10)
  "pr_requestor_user" varchar(100)
  "pr_requestor_email" varchar(150)
  "pr_creator_user" varchar(100)
  "pr_creator_email" varchar(150)
  "purchase_group_code" varchar(50)
  "purchase_group" varchar(100)
  "pr_material_group_number" varchar(10)
  "pr_material_group" varchar(100)
  "external_material_group" varchar(10)
  "pr_company" varchar(6)
  "vendor_code" varchar(15)
  "plant_code" varchar(4)
  "plant_name" varchar(35)
  "company_name" varchar(50)
  "company_address" text
  "sap_material_number" varchar(50)
  "delivery_date" datetime
  "cs_id" int
  "document_type" varchar(10)
  "spend_channel" varchar(10)
  "dept_head_name" varchar(100)
  "dept_head_email" varchar(150)
  "createdAt" datetime [not null]
  "updatedAt" datetime [not null]
}

Table "qcf_counters" {
  "id" int [pk, not null, increment]
  "current_number" int [not null, default: 0]
  "last_updated" datetime [not null]
}

Table "qcf_library" {
  "id" int [pk, not null, increment]
  "qcf_number" varchar(20) [not null]
  "rfq_number" varchar(15) [not null]
  "pr_number" varchar(15) [not null]
  "item_code" varchar(10)
  "item_text" text
  "quantity" int
  "uom" varchar(10)
  "item_value" decimal(10,2)
  "vendor_price" decimal(10,2)
  "delivery_date" datetime
  "vendor_delivery_date" datetime
  "vendor_description" varchar(255)
  "pr_release_date" datetime
  "server_groups" varchar(10)
  "purchase_group_code" varchar(50)
  "purchase_group" varchar(100)
  "pr_requestor_user" varchar(100)
  "pr_requestor_email" varchar(150)
  "pr_creator_user" varchar(100)
  "pr_creator_email" varchar(150)
  "pr_material_group_number" varchar(50)
  "pr_material_group" varchar(100)
  "external_material_group" varchar(10)
  "vendor_code" varchar(50) [not null]
  "plant_code" varchar(4)
  "plant_name" varchar(35)
  "company_name" varchar(50)
  "company_address" text
  "sap_material_number" varchar(50)
  "cs_id" int
  "cl_id" int
  "management_id" int [note: 'User ID of management who approved the QCF']
  "tipe_rfq" varchar(15)
  "quotation_number" varchar(15)
  "quotation_date" datetime
  "cl_comment" text
  "management_comment" text [note: 'Comment provided by management during QCF approval']
  "is_sync" tinyint(1)
  "createdAt" datetime [not null]
  "updatedAt" datetime [not null]
  "qcf_approved" tinyint(1)
  "rfq_item_id" int
  "status_milestone" int
  "sync_message" text
  "po_number" varchar(15)
  "document_type" varchar(10)
  "spend_channel" varchar(10)
  "category" varchar(10)
  "sub_category" varchar(10)
  "cl_approved_at" datetime
  "management_approved_at" datetime
  "approval_config" varchar(255)

  Indexes {
    qcf_number [type: btree, name: "idx_qcf_qcf_number"]
    rfq_item_id [type: btree, name: "idx_qcf_rfq_item_id"]
    (status_milestone, pr_release_date) [type: btree, name: "idx_qcf_status_release"]
    rfq_item_id [type: btree, name: "rfq_item_id"]
  }
}

Table "qcf_token_email" {
  "id" int [pk, not null, increment]
  "qcf_number" varchar(15) [not null]
  "rfq_number" varchar(15)
  "pr_number" varchar(15) [not null]
  "server_groups" varchar(10) [not null]
  "qcf_token" text [not null]
  "date_expired" datetime
  "is_active" tinyint(1) [default: 0]
  "created_at" datetime
  "updated_at" datetime
  "user_type" varchar(10)
  "vendor_code" varchar(15)
  "config_condition" varchar(255) [note: 'Config condition name from config_autopo']
}

Table "rfq_counters" {
  "id" int [pk, not null, increment]
  "current_number" int [not null, default: 0]
  "last_updated" datetime [not null]
}

Table "rfq_library" {
  "id" int [pk, not null, increment]
  "uuid" varchar(64) [not null]
  "rfq_number" varchar(15) [not null]
  "pr_number" varchar(15) [not null]
  "item_code" varchar(10)
  "quantity" int
  "uom" varchar(10)
  "item_value" decimal(10,2)
  "src_value" decimal(10,2)
  "src_currency" varchar(5)
  "convert_value" decimal(10,2)
  "convert_currency" varchar(5)
  "pr_release_date" datetime
  "server_groups" varchar(10)
  "purchase_group_code" varchar(50)
  "purchase_group" varchar(100)
  "pr_material_group_number" varchar(50)
  "pr_material_group" varchar(100)
  "external_material_group" varchar(10)
  "vendor_code" varchar(50) [not null]
  "plant_code" varchar(4)
  "plant_name" varchar(35)
  "status_vendor" int [note: '0 = no action, 1 = approve, 2 = reject']
  "vendor_batch" int [note: 'berapa kali rfq masuk ke vendor']
  "vendor_sequence" int [note: '1 = direct-first, 2 = aggregator-second, 3 = parallel']
  "status_dic" int [note: '1 = approve, 2 = reject, 3, need review']
  "dic_batch" int [note: 'berapa kali rfq masuk ke user']
  "tipe_rfq" varchar(15)
  "status_milestone" int [note: 'lihat di config milestone']
  "createdAt" datetime [not null]
  "updatedAt" datetime [not null]
  "item_text" text
  "cs_id" int
  "delivery_date" datetime
  "location" varchar(255)
  "vendor_price" decimal(10,2)
  "vendor_delivery_date" datetime
  "vendor_description" varchar(255)
  "reject_reason" varchar(255)
  "vendor_reject_reason" varchar(255)
  "pr_requestor_user" varchar(100)
  "pr_requestor_email" varchar(150)
  "pr_creator_user" varchar(100)
  "pr_creator_email" varchar(150)
  "cl_id" int
  "cl_comment" text
  "quotation_number" varchar(15)
  "quotation_date" datetime
  "company_name" varchar(50)
  "company_address" text
  "sap_material_number" varchar(50)
  "vendor_code_2" varchar(50) [not null]
  "dept_head_name" varchar(100)
  "dept_head_email" varchar(150)
  "sourcing_reason" varchar(50)
  "sourcing_notes" text
  "document_type" varchar(10)
  "spend_channel" varchar(10)
  "vendor_type" varchar(10) [default: 'direct']
  "category" varchar(10)
  "sub_category" varchar(10)
  "vendor_specification" text [note: 'Product specification offered by vendor']
  "vendor_brand" varchar(100) [note: 'Product brand offered by vendor']
  "vendor_warranty" int [note: 'Warranty duration in months offered by vendor']
  "vendor_sloc" varchar(255) [note: 'Storage Location (SLOC) codes selected by vendor (comma-separated)']
  "vendor_address_details" text [note: 'Detailed delivery address offered by vendor']

  Indexes {
    (cs_id, pr_release_date, status_milestone) [type: btree, name: "idx_rfq_cs_release_milestone"]
    (pr_release_date, rfq_number, vendor_code, vendor_batch) [type: btree, name: "idx_rfq_release_rfq_vendor_batch"]
    (vendor_batch, vendor_code, rfq_number) [type: btree, name: "idx_rfq_rfq_vendor_batch"]
    (vendor_code, pr_release_date, status_milestone) [type: btree, name: "idx_rfq_vendor_release_milestone"]
  }
}

Table "rfq_token_email" {
  "id" int [pk, not null, increment]
  "rfq_number" varchar(15) [not null]
  "pr_number" varchar(15) [not null]
  "server_groups" varchar(10) [not null]
  "rfq_token" text [not null]
  "date_expired" datetime
  "is_active" tinyint(1) [default: 0]
  "created_at" datetime
  "updated_at" datetime
  "user_type" varchar(10)
  "vendor_batch" int
  "vendor_code" varchar(15)
  "config_condition" varchar(255) [note: 'Config condition name from config_autopo']

  Indexes {
    (user_type, rfq_number, vendor_batch, date_expired) [type: btree, name: "idx_rte_dic_latest"]
    (vendor_code, is_active, date_expired, rfq_number, user_type, vendor_batch) [type: btree, name: "idx_rte_vendor_expired_lookup"]
    (date_expired, vendor_code, rfq_number, vendor_batch, user_type) [type: btree, name: "idx_rte_vendor_latest"]
  }
}

