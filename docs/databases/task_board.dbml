  "selection" int [not null]
  "appointment" int [not null]
  "created_at" timestamp [not null, default: `CURRENT_TIMESTAMP`]
}

Table "password_resets" {
  "email" varchar(255) [not null]
  "token" varchar(255) [not null]
  "created_at" "timestamp on update CURRENT_TIMESTAMP" [not null, default: `CURRENT_TIMESTAMP`]

  Indexes {
    email [type: btree, name: "password_resets_email_index"]
    token [type: btree, name: "password_resets_token_index"]
  }
}

Table "pr_approval" {
  "approval_id" int [pk, not null, increment]
  "pr_number" varchar(20) [not null]
  "item_id" int
  "user_id" int [not null]
  "pr_activity" varchar(25)
  "pr_app_code" varchar(25) [note: '1=Request(closePR, PausePR, Reset), 2=approved(closePR, PausePR, Reset); 3=rejected']
  "app_status" int [not null, note: '1 = REQ, 2 = APPROVE , 3 = REJECTED']
  "created_at" datetime
  "approve_at" datetime
  "app_comment" text
  "reject_comment" text
  "app_sequence" int [default: 0]
  "file_restore" varchar(200)

  Indexes {
    (user_id, item_id) [type: btree, name: "item_id"]
    (pr_activity, pr_app_code) [type: btree, name: "pr_activity"]
    pr_number [type: btree, name: "pr_number"]
  }
  Note: 'Notifikasi Approval Table'
}

