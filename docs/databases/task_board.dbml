Table "board" {
  "id" "int unsigned" [pk, not null, increment]
  "user_id" "int unsigned" [not null]
  "boardTitle" varchar(255) [not null]
  "is_starred" tinyint(1) [not null]
  "boardPrivacyType" varchar(255) [not null]
  "created_at" timestamp
  "updated_at" timestamp

  Indexes {
    user_id [type: btree, name: "board_user_id_foreign"]
  }
}

Table "board_card" {
  "id" "int unsigned" [pk, not null, increment]
  "board_id" "int unsigned" [not null]
  "user_id" "int unsigned" [not null]
  "list_id" "int unsigned" [not null]
  "card_title" varchar(25)
  "card_description" text
  "card_color" varchar(10)
  "due_date" "timestamp on update CURRENT_TIMESTAMP" [not null, default: `CURRENT_TIMESTAMP`]
  "pr_company_groups" varchar(10)
  "company" int
  "is_priority" board_card_is_priority_enum [default: '0']
  "pr_release_date" datetime
  "pr_value" decimal(12,0) [default: 0, note: 'PR Value']
  "currency" varchar(10)
  "convert_value" bigint
  "convert_currency" varchar(5)
  "pr_material_group" varchar(100)
  "pr_service_group" varchar(100)
  "pr_material_group_number" varchar(10)
  "pr_service_group_number" varchar(10)
  "pr_requestor_user" varchar(100)
  "pr_requestor_email" varchar(150)
  "pr_creator_user" varchar(150)
  "pr_creator_email" varchar(200)
  "purchase_group" varchar(100)
  "complete" board_card_complete_enum [not null, default: '0', note: '0:onprogres\\r\\n1:complete\\r\\n2:inactive\\r\\n3:waitingCancel\\r\\n4:cancel\\r\\n5:waitingClose\\r\\n6:close\\r\\n7:waiting restore\\n8:RequestReject\\n9:autoClosed']
  "created_at" timestamp [not null, default: `CURRENT_TIMESTAMP`]
  "updated_at" timestamp
  "partial_status" varchar(5)
  "po_number" varchar(20)
  "spend_channel" varchar(45)
  "pr_risk" varchar(5)
  "pr_permit1" varchar(200)
  "pr_permit2" varchar(200)
  "pr_permit3" varchar(200)
  "purchase_group_code" varchar(50)
  "sources" varchar(10) [default: 'SAP']
  "pr_reff" varchar(100)
  "split_from" varchar(20)
  "split_no" int
  "split_for" board_card_split_for_enum
  "is_updated" tinyint(1) [default: 0]
  "tor_number" varchar(15)
  "tor_status" varchar(15)
  "tor_release_date" datetime
  "tor_link" text
  "im_number" varchar(20)

  Indexes {
    card_title [type: btree, name: "board_card_idx_card_title"]
    (complete, user_id, id) [type: btree, name: "board_card_idx_complete_user_id_id"]
    (complete, user_id, pr_release_date) [type: btree, name: "board_card_idx_complete_user_id_pr_date"]
    card_color [type: btree, name: "card_color"]
    company [type: btree, name: "company"]
    complete [type: btree, name: "complete"]
    (pr_release_date, complete, list_id, user_id, card_title) [type: btree, name: "complete_list_id_user_id_card_title_pr_release_date"]
    list_id [type: btree, name: "list_id"]
    user_id [type: btree, name: "user_id"]
  }
}

Table "board_list" {
  "id" "int unsigned" [pk, not null, increment]
  "board_id" "int unsigned" [not null]
  "user_id" "int unsigned" [not null]
  "asigned_id" int [not null]
  "list_name" varchar(255) [not null]
