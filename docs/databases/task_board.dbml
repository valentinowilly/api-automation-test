Table "csi_rating" {
  "id" int [pk, not null, increment]
  "pr_number" varchar(100) [not null]
  "pr_desc" varchar(255)
  "pr_requestor" varchar(100)
  "pr_requestor_email" varchar(100)
  "cl_name" varchar(255)
  "cs_name" varchar(255)
  "pr_sla" int [default: 0]
  "csi_rating" int [default: 0]
  "csi_comment" text
  "csi_status" int [default: 0, note: '0 : new, 1 : send by cs (manual), 2 : send by system (auto)']
  "csi_name" varchar(255)
  "csi_email" varchar(255)
  "csi_rated" int [default: 0, note: '0 : not rated, 1 : rated by requestor, 2: rated by system']
  "csi_invitationstatus" mediumtext [note: 'terkirim / bounce']
  "csi_invitationdate" datetime [note: 'Tanggal terakhir kirim invitation csi']
  "csi_expireddate" date
  "csi_expmanual" date [note: 'expired untuk manual invitation']
  "created_at" datetime
  "updated_at" "timestamp on update CURRENT_TIMESTAMP" [default: `CURRENT_TIMESTAMP`]
  "po_number" varchar(150)
  "item_id" int

  Indexes {
    pr_number [type: btree, name: "idx_csi_rating_pr_number"]
  }
  Note: 'New CSI Rating Table'
}

Table "csi_rating_invitation" {
  "id" int [pk, not null, increment]
  "id_csi_rating" int [not null]
  "token" varchar(100) [not null]
  "is_valid" tinyint(1) [not null]
  "created_at" datetime [not null, default: `CURRENT_TIMESTAMP`]
  "updated_at" "datetime on update CURRENT_TIMESTAMP" [not null, default: `CURRENT_TIMESTAMP`]
}

Table "currency" {
  "id" int [pk, not null, increment]
  "currency_code" varchar(30)
  "currency_desc" varchar(60)
}

