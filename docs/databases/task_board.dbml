  "groupId" varchar(10) [not null]
  "groupName" varchar(75) [not null]
  "created_at" datetime
  "updated_at" datetime
  "company_inisial" varchar(10)

  Indexes {
    company_code [type: btree, name: "company_code"]
  }
}

Table "contracts" {
  "id" "int unsigned" [pk, not null, increment]
  "pr_number" varchar(255) [not null]
  "checked" int [not null, default: 0]
  "created_at" timestamp
  "updated_at" timestamp
  "item_id" int [unique]

  Indexes {
    checked [type: btree, name: "checked"]
    pr_number [type: btree, name: "pr_number"]
  }
}

Table "counter_split_pr_items" {
  "id" int [pk, not null, increment]
