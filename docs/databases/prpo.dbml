  "pr_close" varchar(15)
  "value" double
  "currency" text
  "src_value" double [note: 'untuk keperluan isourcing']
  "src_currency" varchar(7) [note: 'untuk keperluan isourcing']
  "created_date" datetime
  "week" int
  "c_last_approval" varchar(5)
  "c_final_approval" varchar(5)
  "c1_division" varchar(100)
  "c2_division" varchar(100)
  "c3_division" varchar(100)
  "c4_division" varchar(100)
  "c5_division" varchar(100)
  "c6_division" varchar(100)
  "updated_at" timestamp
  "total_leadtime" int
  "interim" varchar(5)
}

