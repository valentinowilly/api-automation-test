  "c1_datetime" datetime
  "c1_leadtime" int
  "c2_division" varchar(150)
  "c2_pic" varchar(100)
  "c2_datetime" datetime
  "c2_leadtime" int
  "c3_division" varchar(150)
  "c3_pic" varchar(100)
  "c3_datetime" datetime
  "c3_leadtime" int
  "c4_division" varchar(150)
  "c4_pic" varchar(100)
  "c4_datetime" datetime
  "c4_leadtime" int
  "c5_division" varchar(150)
  "c5_pic" varchar(100)
  "c5_datetime" datetime
  "c5_leadtime" int
  "c6_division" varchar(150)
  "c6_pic" varchar(100)
  "c6_datetime" datetime
  "c6_leadtime" int

  Indexes {
    po_number [type: btree, name: "idx_po_detail_item_po_number"]
    pr_number [type: btree, name: "idx_po_detail_item_pr_number"]
  }
}

Table "pr_dashboard" {
  "id" int [pk, not null, increment]
  "company_id" int
  "division_code" varchar(50)
  "division_name" varchar(100) [note: 'Division Name']
