Table "sap_storage_location" {
  "server" char(4) [not null]
  "plant_code" char(4) [not null]
  "storage_location_code" char(4) [not null]
  "storage_location_name" char(16)
  "send_date" datetime

  Indexes {
    (server, plant_code, storage_location_code) [pk, name: "PRIMARY"]
  }
}

Table "schema_migrations_prpo" {
  "version" varchar(20) [pk, not null]
  "applied_at" timestamp [default: `CURRENT_TIMESTAMP`]
}

Table "search_library" {
  "id" int [pk, not null, increment, note: '1o = iSourcing']
  "tipe_data" varchar(9) [note: '(1o) DASHBOARD (Header) or DETAILS']
  "pr_number" varchar(20) [note: '(1o) PR Number']
  "im_number" varchar(20) [note: 'internal Memo (IM)']
  "pi_number" varchar(20) [note: 'TBD']
  "jumlah_po" int [note: '(1o) Jumlah PO Per line item']
  "po_number" varchar(20) [note: '(1o) Po number']
  "material_identification" varchar(1) [note: 'TBD']
  "material_number" varchar(10) [note: '(1o) Dashboard = jumlah item, Detail tipe PR = Line Item, Detail Tipe PO = Line PO']
  "pr_type" varchar(10)
  "pr_material_number" int [note: '(1o) Join untuk PO terhadap line item PR']
  "pr_material_group" varchar(100) [note: '(1o) Matl group name']
  "pr_service_group" varchar(100) [note: '(1o) Matl service group name']
  "pr_material_group_number" varchar(10) [note: '(1o) Matl group number']
  "pr_service_group_number" varchar(10) [note: '(1o) Matl service group number']
  "pr_requestor_user" varchar(100) [note: '(1o) Kolom requested by pada PR']
  "pr_requestor_email" varchar(150) [note: '(1o) Kolom email PIC pengadaan pada PR (Email csi)']
  "pr_creator_user" varchar(150) [note: '(1o) User ID SAP (creator PR)']
  "pr_creator_email" varchar(200) [note: '(1o) email SAP (creator PR)']
  "text" text [note: '(1o) Short text (matl description)']
  "tipe" varchar(2) [note: '(1o) PR atau PO']
  "qty_item" int [not null, default: 0, note: '(1o) PR qty item']
  "unit_item" varchar(10) [note: '(1o) uom']
  "value" bigint [not null, note: '(1o) value convert to USD']
  "currency" varchar(5) [note: '(1o) USD']
  "src_value" bigint [note: '(1o) value sesuai PR SAP (bisa IDR atau USD)']
  "src_currency" varchar(5) [note: '(1o) currency sesuai PR SAP (bisa IDR atau USD)']
  "groups" varchar(10) [note: '(1o) Server SAP (gems,BC,BKES)']
  "company" varchar(6) [not null, note: '(1o) company code']
  "create_date" datetime [not null, note: '(1o) PR created date']
  "pr_release_date" datetime [note: '(1o) PR released date']
  "po_create_date" datetime [note: '(1o) PO created date']
  "po_release_date" datetime [note: '(1o) PO released date']
  "status" varchar(50) [not null, note: '(1o) full released: jika pr/po sudah full released. outstanding: jika blm fully approved']
  "outline" varchar(20) [note: '(1o)']
  "spend_channel" varchar(20) [note: '(1o)']
  "pr_close" varchar(15)
  "division" varchar(100) [not null, note: '(1o)']
  "purchase_group" varchar(100) [not null, note: '(1o) purchasing group name']
  "approval_leadtime" int
  "qcf_leadtime" int
  "pr_risk" varchar(5) [note: '(1o) BC: tingkat risiko. GEMS?']
  "pr_permit1" varchar(200) [note: '(1o)']
  "pr_permit2" varchar(200) [note: '(1o)']
  "pr_permit3" varchar(200) [note: '(1o)']
  "region" varchar(20) [note: '(1o)']
  "price_item_idr" bigint [note: '(1o)']
  "acc_assign" varchar(10) [note: '(1o) account assignment code']
  "purchase_group_code" varchar(50) [note: '(1o) purchasing group code']
  "oa_number" varchar(15) [note: '(1o) oa number']
  "oa_valid_end" date [note: '(1o) oa validity end']
  "oa_category" varchar(10) [note: '(1o)']
  "oa_requester" varchar(150) [note: '(1o)']
  "text_repeatorder" text [note: '(1o)']
  "interim" varchar(5) [note: '(1o) jika 1 maka di exclude dari iSourcing']
  "c1_pic" varchar(100) [note: 'L1 approve by (user id sap name)']
  "c1_leadtime" int
  "c1_division" varchar(150) [note: 'L1 approve by (MLA desc code)']
  "c1_datetime" datetime [note: 'L1 approval date time']
  "c2_pic" varchar(100) [note: 'L2 approve by (user id sap name)']
  "c2_leadtime" int
  "c2_division" varchar(150) [note: 'L2 approve by (MLA desc code)']
  "c2_datetime" datetime [note: 'L2 approval date time']
  "c3_pic" varchar(100) [note: 'L3 approve by (user id sap name)']
  "c3_leadtime" int
  "c3_datetime" datetime [note: 'L3 approval date time']
  "c3_division" varchar(150) [note: 'L3 approve by (MLA desc code)']
  "c4_pic" varchar(100) [note: 'L4 approve by (user id sap name)']
  "c4_leadtime" int
  "c4_datetime" datetime [note: 'L4 approval date time']
  "c4_division" varchar(150) [note: 'L4 approve by (MLA desc code)']
  "c5_pic" varchar(100) [note: 'L5 approve by (user id sap name)']
  "c5_leadtime" int
  "c5_datetime" datetime [note: 'L5 approval date time']
  "c5_division" varchar(150) [note: 'L5 approve by (MLA desc code)']
  "c6_pic" varchar(100) [note: 'L6 approve by (user id sap name)']
  "c6_leadtime" int
  "c6_datetime" datetime [note: 'L6 approval date time']
  "c6_division" varchar(150) [note: 'L6 approve by (MLA desc code)']
  "is_delete" tinyint
  "is_oa" tinyint
  "is_newItem" tinyint
  "is_service" tinyint
  "oem" varchar(18)
  "external_material_group" varchar(10)
  "external_material_group_name" varchar(60)
  "nomor_material_sap" varchar(18) [note: 'material_number_asli']
  "plant_code" varchar(4)
  "plant_name" varchar(40)
  "delivery_date" datetime
  "send_date" datetime
  "brand" varchar(50)
  "garansi" tinyint
  "is_da" tinyint
  "storage_location_code" char(4)

  Indexes {
    (groups, company) [type: btree, name: "groups"]
    (po_number, pi_number, im_number) [type: btree, name: "im_number"]
    pr_number [type: btree, name: "numbernya_UNIQUE"]
    purchase_group [type: btree, name: "purchase_group"]
    `text(500)` [type: btree, name: "text_UNIQUE"]
    (tipe_data, tipe, status) [type: btree, name: "tipe_data"]
  }
}

Table "settings" {
  "name" varchar(255) [pk, not null]
  "value" text
}

Table "snapshot_chart_personal" {
  "id" int [pk, not null, increment]
  "chart_name" varchar(5) [not null, note: 'MTD, YTD']
  "snapshot_date" datetime [note: 'now()']
  "tipe" varchar(5) [not null, note: 'PR, PO, PRPO']
  "personal_name" varchar(150) [not null]
  "term" varchar(7) [not null, note: 'eg, 01-2017']
  "days" varchar(5) [note: 'eg : >= 8']
  "total" varchar(5) [note: 'total_pr/po']
  "avg_lead_time" varchar(3) [note: 'average pr/po per sla_day']
  "sla_on_target" varchar(3) [note: 'prosentase']
  Note: 'Snapshoot_Chart_Personal'
}

Table "sourcing_status" {
  "id" int [pk, not null, increment]
  "pr_number" varchar(20) [not null]
  "pr_isearch" varchar(20) [not null]
  "company_group" varchar(5) [not null]
  "latest_status" text
  "cs_name" varchar(255)
  "milestone" varchar(100)
  "pr_status" varchar(100)
}

Table "system_activity" {
  "id" int [pk, not null, increment]
  "changed_in" varchar(255) [not null]
  "activity_description" text [not null]
  "created_at" timestamp
  "updated_at" timestamp
}

Table "test_table" {
  "idtest_table" int [pk, not null, increment]
  "test_date" datetime
  "test_tablecol" varchar(45)
}

Table "users" {
  "id" "int unsigned" [pk, not null, increment]
  "name" varchar(255) [not null]
  "email" varchar(255) [unique, not null]
  "password" varchar(255) [not null]
  "api_token" varchar(60) [unique, not null]
  "remember_token" varchar(100)
  "created_at" timestamp
  "updated_at" timestamp
  "avatar" varchar(255)
  "google_id" varchar(255)
  "expires_in" int
}
