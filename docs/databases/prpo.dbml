Table "PRPO_SAP_2024" {
  "server" varchar(10) [not null]
  "pr_number" varchar(10) [not null]
  "PR_released_date" date [not null]
  "PO_created_date" date [not null]
  "category" varchar(10) [not null]
  Note: '''SELECT pr.server, pr.pr_number, min(pr.released_date) as PR_released_date, 
max(po.created_date) AS PO_created_date, c.category FROM pr
LEFT JOIN sap_search_library s ON pr.pr_number = s.pr_number
LEFT JOIN po ON pr.pr_number = po.pr_number AND pr.server = po.server
LEFT JOIN custom_procurement_category c ON po.created_by = c.user_id
WHERE 
year(pr.released_date) = \'2024\'
AND pr.purchasing_group_code !=\'BPA\'
AND c.category IS not NULL
AND c.category NOT IN (\'OA\', \'MRR-VHS\')
AND pr.deleted = 0
AND po.deleted = 0
GROUP BY pr.server, pr.pr_number, c.category'''
}

